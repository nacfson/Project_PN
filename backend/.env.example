APP_ADDR=:8080
DATABASE_URL=postgres://project_pn:project_pn_dev_password@localhost:5433/project_pn_dev?sslmode=disable
MIGRATIONS_PATH=file://db/migrations

# Word enrichment (OpenAI-compatible chat-completions endpoint).
# Examples:
#   Groq:     ENRICH_BASE_URL=https://api.groq.com/openai/v1   ENRICH_MODEL=llama-3.1-8b-instant
#   DeepSeek: ENRICH_BASE_URL=https://api.deepseek.com/v1      ENRICH_MODEL=deepseek-chat
#   Gemini:   ENRICH_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  ENRICH_MODEL=gemini-2.0-flash
# Leave ENRICH_BASE_URL empty to disable generation (cache-only lookups still work).
ENRICH_BASE_URL=
ENRICH_API_KEY=
ENRICH_MODEL=

# Single seeded dev user (no auth in MVP). Must match migration 000002.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TARGET_LANG=en
DEFAULT_DEFINITION_LANG=ko

# Optional language restriction/override for new registrations.
# ALLOWED_* are comma-separated ISO 639-1 codes; empty means unrestricted.
# FORCE_* override user selection entirely and hide the selector in the UI.
ALLOWED_TARGET_LANGS=
ALLOWED_DEFINITION_LANGS=
FORCE_TARGET_LANG=
FORCE_DEFINITION_LANG=

# App UI language defaults and restrictions (ISO 639-1 codes).
DEFAULT_UI_LANGUAGE=en
ALLOWED_UI_LANGUAGES=
FORCE_UI_LANGUAGE=

# CORS origins allowed to call the API (comma-separated).
# Covers Expo web dev (:8081 / :19006) and Tauri desktop WebView origins.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,tauri://localhost,http://tauri.localhost

# Auth
SESSION_TTL=720h
EMAIL_VERIFICATION_TTL=24h
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM=
APP_PUBLIC_URL=http://localhost:8080
