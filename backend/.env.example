APP_ADDR=:8080
DATABASE_URL=postgres://project_pn:project_pn_dev_password@localhost:5433/project_pn_dev?sslmode=disable
MIGRATIONS_PATH=file://db/migrations

# Local PostgreSQL credentials used by backend/compose.yaml.
# These must match DATABASE_URL above.
POSTGRES_USER=project_pn
POSTGRES_PASSWORD=project_pn_dev_password
POSTGRES_DB=project_pn_dev

# Word enrichment (OpenAI-compatible chat-completions endpoint).
# Primary provider (tried first):
#   Gemini:   ENRICH_PRIMARY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai   ENRICH_PRIMARY_MODEL=gemini-3.1-flash-lite
#   Groq:     ENRICH_PRIMARY_BASE_URL=https://api.groq.com/openai/v1                           ENRICH_PRIMARY_MODEL=llama-3.1-8b-instant
# Fallback provider (tried when primary fails):
#   DeepSeek: ENRICH_FALLBACK_BASE_URL=https://api.deepseek.com   ENRICH_FALLBACK_MODEL=deepseek-v4-flash
# Legacy ENRICH_BASE_URL / ENRICH_API_KEY / ENRICH_MODEL are aliases for PRIMARY.
# Leave both BASE_URLs empty to disable generation (cache-only lookups still work).
ENRICH_PRIMARY_BASE_URL=
ENRICH_PRIMARY_API_KEY=
ENRICH_PRIMARY_MODEL=
ENRICH_FALLBACK_BASE_URL=
ENRICH_FALLBACK_API_KEY=
ENRICH_FALLBACK_MODEL=

# Single seeded dev user (no auth in MVP). Must match migration 000002.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TARGET_LANG=en
DEFAULT_DEFINITION_LANG=ko

# Optional language restriction/override for new registrations.
# ALLOWED_* are comma-separated ISO 639-1 codes; empty means unrestricted.
# FORCE_* override user selection entirely and hide the selector in the UI.
ALLOWED_TARGET_LANGS=
ALLOWED_DEFINITION_LANGS=
FORCE_TARGET_LANG=
FORCE_DEFINITION_LANG=

# App UI language defaults and restrictions (ISO 639-1 codes).
DEFAULT_UI_LANGUAGE=en
ALLOWED_UI_LANGUAGES=
FORCE_UI_LANGUAGE=

# CORS origins allowed to call the API (comma-separated).
# Covers Expo web dev (:8081 / :19006) and Tauri desktop WebView origins.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,tauri://localhost,http://tauri.localhost

# Chrome extension IDs allowed to call the API directly.
# Set these to the stable IDs shown in chrome://extensions.
PN_DEV_EXTENSION_ID=
PN_PROD_EXTENSION_ID=

# Auth
CENTRAL_AUTH_URL=https://auth.nacfson.cloud
