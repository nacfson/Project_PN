# Backend API base URL (no trailing slash).
# Web / Tauri desktop: http://localhost:8080
# Android emulator: http://10.0.2.2:8080
# Physical device / staging: http://YOUR_LAN_IP:8080 or http://SERVER_IP
# Public deploy / packaged desktop app: http://YOUR_PUBLIC_IP:53412 or https://YOUR_PUBLIC_DOMAIN
# For native release builds, create .env.production with the public endpoint.
# Hosted web exports can omit this when the same public origin reverse-proxies
# the API; native and Tauri builds must set it at build time.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Comma-separated fallback API URLs tried when the primary URL is unreachable.
# Useful for desktop apps: public IP first, LAN IPs as fallback.
# EXPO_PUBLIC_API_FALLBACK_URLS=http://192.168.219.100:53412,http://192.168.219.109:53412

# Auth mode. Use central to sign in through Brain auth while calling this
# platform's API with the returned bearer token.
EXPO_PUBLIC_AUTH_MODE=central
EXPO_PUBLIC_CENTRAL_AUTH_URL=https://auth.nacfson.cloud

# Tauri CSP (src-tauri/tauri.conf.json connect-src): includes http:/https: for staging.
# If you lock CSP down, add your EXPO_PUBLIC_API_BASE_URL origin explicitly.

# Chrome extension ID used to send the login token back to the browser extension.
# Set this to the stable ID shown in chrome://extensions for the unpacked dev build.
# EXPO_PUBLIC_PN_EXTENSION_ID=your_dev_extension_id_here
