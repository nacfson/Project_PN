# Backend API base URL (no trailing slash).
# Web / Tauri desktop: http://localhost:8080
# Android emulator: http://10.0.2.2:8080
# Physical device / staging: http://YOUR_LAN_IP:8080 or http://SERVER_IP
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Google OAuth client IDs (Google Cloud Console — one per platform).
# Web / Tauri desktop: Web application client; add authorized redirect URIs for
#   http://localhost:8081 and projectpn://auth/callback when using Tauri.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS: bundle ID must match app.json / Xcode; redirect URI projectpn://auth/callback
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Android: package + SHA-1; redirect URI projectpn://auth/callback
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Magic links on native/Tauri: set backend APP_PUBLIC_URL=projectpn: so consume
# redirects to projectpn:/auth/callback#code=... (handled by AuthCallbackHandler).
# Web dev: APP_PUBLIC_URL=http://localhost:8081

# Tauri CSP (src-tauri/tauri.conf.json connect-src): includes http:/https: for staging.
# If you lock CSP down, add your EXPO_PUBLIC_API_BASE_URL origin explicitly.
