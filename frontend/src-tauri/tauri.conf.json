{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project PN",
  "version": "1.0.2",
  "identifier": "com.projectpn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npx expo start --web --port 8081",
    "beforeBuildCommand": "npx expo export --platform web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Project PN",
        "width": 1000,
        "height": 720,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["projectpn"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["projectpn"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
