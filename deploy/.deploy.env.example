# Local-only deploy script settings. Copy to deploy/.deploy.env and adjust.
# This file is for scripts/deploy-remote.sh on your Mac, not for Docker Compose on the server.

DEPLOY_HOST=zlUbuntu
DEPLOY_PUBLIC_URL=https://YOUR_PUBLIC_DOMAIN
# Use public for internet-facing deploys. The script refuses localhost/LAN URLs
# in public mode because they cannot be reached outside your intranet.
DEPLOY_ACCESS_SCOPE=public
# Set only when reusing an existing Postgres volume initialized with an older password.
# EXISTING_POSTGRES_PASSWORD=old-password
REMOTE_DIR='~/project-pn/deploy'
IMAGE_NAME=project-pn-backend
PLATFORM=linux/amd64
