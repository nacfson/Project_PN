# Staging deploy defaults (plain HTTP on :80). Copy to deploy/.env and adjust.

POSTGRES_PASSWORD=change_me_staging
DATABASE_URL=postgres://project_pn:change_me_staging@postgres:5432/project_pn?sslmode=disable

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=http://YOUR_SERVER_IP,http://localhost:8081

# Word enrichment (OpenAI-compatible). Leave empty for cache-only lookups.
ENRICH_BASE_URL=
ENRICH_API_KEY=
ENRICH_MODEL=

DEFAULT_TARGET_LANG=en
DEFAULT_DEFINITION_LANG=ko

# Optional language restriction/override for new registrations.
# ALLOWED_* are comma-separated ISO 639-1 codes; empty means unrestricted.
# FORCE_* override user selection entirely and hide the selector in the UI.
ALLOWED_TARGET_LANGS=
ALLOWED_DEFINITION_LANGS=
FORCE_TARGET_LANG=
FORCE_DEFINITION_LANG=

# Auth (Slice 3+). Staging uses log mailer and no email verification gate.
EMAIL_PROVIDER=log
REQUIRE_EMAIL_VERIFIED=false
SESSION_TTL=720h
MAGIC_LINK_TTL=15m
EXCHANGE_CODE_TTL=5m
APP_PUBLIC_URL=http://YOUR_SERVER_IP

# Resend (when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
EMAIL_FROM=auth@example.com

# Google OAuth (comma-separated ID token audiences; match frontend client IDs)
GOOGLE_CLIENT_IDS=
