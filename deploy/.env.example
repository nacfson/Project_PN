# Production deploy defaults. Copy to deploy/.env on zlUbuntu and adjust.
# Requires router port forwarding for public 80/443 and TLS cert files mounted
# at ./certs/fullchain.pem and ./certs/privkey.pem on the server.
#
# The frontend web bundle is built locally by scripts/deploy-remote.sh and
# uploaded to ./web/ on the server. nginx serves it at the root path while
# /api/, /healthz, /readyz, and /auth/callback are proxied to the backend.

BACKEND_IMAGE=project-pn-backend:latest

POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgres://project_pn:change_me_to_a_strong_password@postgres:5432/project_pn?sslmode=disable

# Comma-separated browser origins allowed to call the API.
ALLOWED_ORIGINS=https://YOUR_PUBLIC_DOMAIN,http://localhost:8081

# Auth. Use local for standalone Project PN, central to trust Brain auth.
AUTH_MODE=central
CENTRAL_AUTH_URL=https://auth.nacfson.cloud

# Word enrichment (OpenAI-compatible). Leave empty for cache-only lookups.
# Full multilingual target-language support requires a real multilingual
# OpenAI-compatible model. The local staging fallback
# `english-dictionary-fallback-v1` supports English target words only.
ENRICH_BASE_URL=
ENRICH_API_KEY=
ENRICH_MODEL=

DEFAULT_TARGET_LANG=en
DEFAULT_DEFINITION_LANG=ko

# Optional language restriction/override for new registrations.
# ALLOWED_* are comma-separated ISO 639-1 codes; empty means unrestricted.
# FORCE_* override user selection entirely and hide the selector in the UI.
ALLOWED_TARGET_LANGS=
ALLOWED_DEFINITION_LANGS=
FORCE_TARGET_LANG=
FORCE_DEFINITION_LANG=

# Email. Public local-auth deploy should use real email and verified accounts.
EMAIL_PROVIDER=resend
SESSION_TTL=720h
EMAIL_VERIFICATION_TTL=24h
APP_PUBLIC_URL=https://YOUR_PUBLIC_DOMAIN
# For reverse-proxy deploys, the web app usually shares the API origin.
# Leave empty to default to APP_PUBLIC_URL.
WEB_APP_PUBLIC_URL=

# Resend (when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
EMAIL_FROM=auth@example.com
